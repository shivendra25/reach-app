# Reach environment variables.
# Copy to .env.local and fill in.
# All keys are OPTIONAL during early scaffolding — consumers call requireEnv().

# Supabase (Postgres + Auth)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# LLM provider for the research agent
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Web research data source (semantic search over communities)
EXA_API_KEY=

# Stripe (wired but disabled at launch)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=